# ─── RONIN Orchestration Engine — Environment Template ────────────────────────
# Copy this to .env and fill in your keys:
#   cp .env.example .env
#
# Then encrypt for production:
#   node config/envVault.mjs encrypt
#
# After encrypting, delete the plaintext:
#   rm .env
# ─────────────────────────────────────────────────────────────────────────────

# FREE TIER (powers 60%+ of all requests):
GEMINI_API_KEY=AIza...your-key-here
GROQ_API_KEY=gsk_...your-key-here

# PAID (Agent/Director/Deep workers):
ANTHROPIC_API_KEY=sk-ant-...your-key-here
OPENAI_API_KEY=sk-proj-...your-key-here

# LOCAL (optional — zero cost, requires Ollama running):
OLLAMA_HOST=http://localhost:11434

# INFRASTRUCTURE (optional — defaults shown):
REDIS_HOST=localhost
REDIS_PORT=6379
QDRANT_HOST=localhost
QDRANT_PORT=6333

# COST GUARDRAILS:
DAILY_COST_LIMIT=1.00
OPUS_DAILY_LIMIT=0.50
GPT4O_DAILY_LIMIT=0.30

# SERVER:
PORT=3001
DASHBOARD_PORT=3002
NODE_ENV=development
